#!/usr/bin/env bash
# Pre-commit hook for deep-research repository.
#
# Check 0: Block commits on any branch other than main.
# Check 1: Block commits containing mojibake (double-encoded UTF-8).
# Check 2: Block commits with broken Table of Contents anchor links.
# Check 3: Block commits with invalid front matter (status, dates, DR ID) or draft status.
# Check 4: Block commits with heading anchors that break in VS Code.
# Check 5: Block commits adding YAML front matter to README.md.
# Check 6: Block commits with DR filenames violating naming conventions.
# Check 7: Block commits with cross-references between DR documents.
# Check 8: Block commits with sequenceDiagram containing HTML entities.
# Check 9: Verify Mermaid diagrams compile using the minlag/mermaid-cli docker image.
# Check 10: Block commits with sequenceDiagram Note blocks containing bold typography.
# Check 11: Block commits with sub-sections in the Table of Contents.
# Check 12: Block commits where README.md or llms.txt reference draft DR documents.
# Check 13: Block commits with dark-theme-incompatible colors in Mermaid diagrams.
# Check 14: Block commits with sequence diagrams missing anti-cutoff safeguards.
# Check 15: Block commits with rect blocks missing phantom spacer before end.
# Check 16: Block commits with blockquotes immediately following details tags without a break.
# Check 17: Block commits with sequence diagrams missing individually-collapsible walkthrough steps.
# Check 20: Block commits where ## / ### headings are missing from the ToC.
# Check 21: Block commits with GitHub-incompatible LaTeX math (blocked macros, missing blank lines).
# Check 22: Block commits with redundant <br/> tags after details blocks that immediately precede headings.
# Check 23: Block commits with unbalanced or orphaned HTML <details> tags.
# Check 24: Block commits with invalid or misplaced horizontal rules (---).
# Check 27: Block commits with Appendices nested under Synthesis and Conclusions.
# Check 28: Block commits with literal \n escape sequences inside Mermaid diagrams.
# Check 29: Block commits with mirrorActors: false in Mermaid sequence diagrams.
# Check 30: Block commits with missing or broken chapter numbering.
# Check 31: Block commits with malformed LaTeX grouping (escaped braces in math).
# Check 32: Block commits with multiline display math that opens on the same line as content.
# Check 33: Block commits with changed display-math blocks that KaTeX cannot parse.
# Check 34: Block commits with malformed numeric heading numbering or alpha-suffixed numeric section IDs.
# Check 35: Block commits with raw Markdown bold inside Mermaid node/subgraph labels.
# Install: git config core.hooksPath .githooks

set -euo pipefail

HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"

# ── Check 0: Branch ban — main only ──────────────────────────────────

CURRENT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "detached")

if [ "$CURRENT_BRANCH" != "main" ]; then
  echo "╔══════════════════════════════════════════════════════════════════╗"
  echo "║  ❌ COMMIT BLOCKED — branches are forbidden in this repository  ║"
  echo "╚══════════════════════════════════════════════════════════════════╝"
  echo ""
  echo "  Current branch: $CURRENT_BRANCH"
  echo ""
  echo "  This repository uses a single-branch (main-only) workflow."
  echo "  All commits must be made directly on main."
  echo ""
  echo "  HOW TO FIX:"
  echo "    1. Switch to main:        git checkout main"
  echo "    2. If you have changes:   git stash && git checkout main && git stash pop"
  echo "    3. Delete the branch:     git branch -d $CURRENT_BRANCH"
  echo ""
  exit 1
fi

# Staged authoring sources and Markdown validation targets.
#
# MDX under src/papers/ is the source of truth for DR documents. Generated
# Markdown mirrors under papers/ are validation targets, not the authoring
# surface. Style guides are supporting docs, not publishable DR papers, so they
# are intentionally excluded from DR-document validation.
RAW_STAGED_MD=$(git diff --cached --name-only --diff-filter=ACM -- '*.md' | grep -vE '^papers/DR-[0-9]{4}/DR-[0-9]{4}-style-guide\.md$|^AGENTS\.md$' || true)
STAGED_MDX=$(git diff --cached --name-only --diff-filter=ACM | grep '^src/papers/.*\.mdx$' || true)

# Staged index files: README.md and llms.txt (for Check 12)
STAGED_INDEX=$(git diff --cached --name-only --diff-filter=ACM -- 'README.md' 'llms.txt')

if [ -z "$RAW_STAGED_MD" ] && [ -z "$STAGED_MDX" ] && [ -z "$STAGED_INDEX" ]; then
  exit 0
fi

EXITCODE=0

GENERATED_MIRRORS=""

if [ -n "$STAGED_MDX" ]; then
  mapfile -t STAGED_MDX_FILES <<< "$STAGED_MDX"

  if ! node scripts/compile-mdx.js "${STAGED_MDX_FILES[@]}"; then
    echo "╔══════════════════════════════════════════════════════════════════╗"
    echo "║  ❌ MDX MIRROR COMPILATION FAILED                               ║"
    echo "╚══════════════════════════════════════════════════════════════════╝"
    echo ""
    echo "WHAT HAPPENED:"
    echo "  One or more staged src/papers/*.mdx files could not be compiled"
    echo "  into their Markdown mirrors under papers/."
    echo ""
    echo "HOW TO FIX:"
    echo "  1. Run: node scripts/compile-mdx.js <staged-mdx-path>"
    echo "  2. Fix the reported MDX/source issue."
    echo "  3. Re-stage the affected files and commit again."
    echo ""
    exit 1
  fi

  MIRROR_SYNC_FAILURES=""
  for source in "${STAGED_MDX_FILES[@]}"; do
    mirror="${source#src/}"
    mirror="${mirror%.mdx}.md"
    GENERATED_MIRRORS="${GENERATED_MIRRORS}${mirror}"$'\n'

    if ! git diff --quiet -- "$mirror"; then
      MIRROR_SYNC_FAILURES="${MIRROR_SYNC_FAILURES}\n  ${mirror}"
    fi
  done

  if [ -n "$MIRROR_SYNC_FAILURES" ]; then
    echo "╔══════════════════════════════════════════════════════════════════╗"
    echo "║  ❌ GENERATED MARKDOWN MIRRORS ARE OUT OF SYNC                  ║"
    echo "╚══════════════════════════════════════════════════════════════════╝"
    echo ""
    echo "Affected mirror(s):"
    echo -e "$MIRROR_SYNC_FAILURES"
    echo ""
    echo "WHAT HAPPENED:"
    echo "  Staged MDX sources were compiled, and their corresponding papers/"
    echo "  Markdown mirrors changed in the working tree. Those mirror updates"
    echo "  are not fully staged yet."
    echo ""
    echo "HOW TO FIX:"
    echo "  1. Stage the listed mirror files with git add."
    echo "  2. Re-run the commit."
    echo ""
    EXITCODE=1
  fi
fi

ORPHAN_MIRROR_FAILURES=""
for file in $RAW_STAGED_MD; do
  if printf '%s\n' "$file" | grep -qE '^papers/DR-[0-9]{4}/DR-[0-9]{4}-.*\.md$'; then
    source="src/${file%.md}.mdx"
    if [ -f "$source" ] && ! printf '%s\n' "$STAGED_MDX" | grep -qxF "$source"; then
      ORPHAN_MIRROR_FAILURES="${ORPHAN_MIRROR_FAILURES}\n  ${file}"
    fi
  fi
done

if [ -n "$ORPHAN_MIRROR_FAILURES" ]; then
  echo "╔══════════════════════════════════════════════════════════════════╗"
  echo "║  ❌ GENERATED PAPER MIRRORS STAGED WITHOUT SOURCE MDX           ║"
  echo "╚══════════════════════════════════════════════════════════════════╝"
  echo ""
  echo "Affected mirror(s):"
  echo -e "$ORPHAN_MIRROR_FAILURES"
  echo ""
  echo "WHAT HAPPENED:"
  echo "  A generated papers/DR-*.md mirror was staged without staging the"
  echo "  corresponding src/papers/*.mdx authoring source."
  echo ""
  echo "HOW TO FIX:"
  echo "  1. Edit and stage the matching src/papers/*.mdx source, then let"
  echo "     the hook validate the compiled mirror."
  echo "  2. If the mirror changed only because of generation, stage the"
  echo "     matching MDX source as well."
  echo ""
  EXITCODE=1
fi

MANUAL_STAGED_MD=$(printf '%s\n' "$RAW_STAGED_MD" | grep -vE '^papers/DR-[0-9]{4}/DR-[0-9]{4}-.*\.md$' || true)
STAGED_MD=$(printf '%s\n%s' "$MANUAL_STAGED_MD" "$GENERATED_MIRRORS" | awk 'NF && !seen[$0]++')
STAGED_AUTHORING_DOCS=$(printf '%s\n%s' "$MANUAL_STAGED_MD" "$STAGED_MDX" | awk 'NF && !seen[$0]++')

# ── Check 1: Mojibake (encoding corruption) ──────────────────────────

MOJIBAKE_PATTERNS=$'Â§|â€"|â€™|â€˜|â€œ|â†\047|âœ…|â❌|âš\047'

FAILURES=""
for file in $STAGED_MD; do
  if git diff --cached -- "$file" | grep -qP "$MOJIBAKE_PATTERNS"; then
    FAILURES="$FAILURES\n  $file"
  fi
done

if [ -n "$FAILURES" ]; then
  echo "╔══════════════════════════════════════════════════════════════════╗"
  echo "║  ❌ ENCODING CORRUPTION (MOJIBAKE) DETECTED                    ║"
  echo "╚══════════════════════════════════════════════════════════════════╝"
  echo ""
  echo "Affected file(s):"
  echo -e "$FAILURES"
  echo ""
  echo "WHAT HAPPENED:"
  echo "  Characters were double-encoded (UTF-8 bytes re-interpreted as"
  echo "  Latin-1/CP-1252 and then re-encoded to UTF-8). For example:"
  echo "    Â§  should be §     â€\"  should be — or –"
  echo "    â€™  should be '     â†'  should be →"
  echo "    âœ…  should be ✅"
  echo ""
  echo "HOW TO FIX:"
  echo "  1. Unstage the file:  git reset HEAD <file>"
  echo "  2. Find corrupted lines:  grep -Pn 'Â§|â€\"|â€™|â†' <file>"
  echo "  3. Replace corrupted characters with the correct Unicode originals"
  echo "     using your editor's find-and-replace (do NOT re-save the whole"
  echo "     file through a different encoding — that will make it worse)."
  echo "  4. If the file is badly corrupted, restore from the last clean"
  echo "     commit:  git checkout HEAD -- <file>"
  echo "  5. Re-stage and commit."
  echo ""
  EXITCODE=1
fi

# ── Check 2: ToC anchor link validation ──────────────────────────────

# We validate against the working-tree version of the file (which includes
# staged changes) rather than extracting blobs, because the ToC and headings
# need to be checked as a coherent whole.

TOC_FAILURES=""
for file in $STAGED_MD; do
  if [ -f "$file" ]; then
    if ! python3 "$HOOK_DIR/validate-toc-links.py" "$file"; then
      TOC_FAILURES="yes"
    fi
  fi
done

if [ -n "$TOC_FAILURES" ]; then
  echo ""
  echo "HOW TO FIX broken ToC links:"
  echo "  The anchor in the ToC does not match any heading in the document."
  echo "  Standard GitHub-compatible anchors are generated by: lowercasing,"
  echo "  removing non-word characters (except spaces and hyphens), and"
  echo "  collapsing consecutive spaces and hyphens into a single hyphen."
  echo ""
  echo "  To re-validate:  python3 .githooks/validate-toc-links.py <file>"
  echo ""
  EXITCODE=1
fi

